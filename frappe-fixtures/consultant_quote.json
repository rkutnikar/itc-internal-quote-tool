{
  "doctype": "DocType",
  "name": "Consultant Quote",
  "module": "Custom",
  "custom": 1,
  "naming_rule": "By \"Naming Series\" field",
  "autoname": "naming_series:",
  "track_changes": 1,
  "editable_grid": 1,
  "engine": "InnoDB",
  "field_order": [
    "naming_series", "status", "customer", "customer_priority", "column_break_1",
    "valid_until", "prepared_by", "section_requirement", "years_experience",
    "certification_required", "certification_held", "skill_type", "column_break_2",
    "duration_months", "budget_per_month", "section_resource", "resource_type",
    "employee", "supplier", "resource_name", "column_break_3", "monthly_cost",
    "manual_cost", "section_pricing", "price_good", "price_better", "price_best",
    "column_break_4", "min_bill_amount", "tier_selected", "discount_pct_applied",
    "section_final", "final_monthly_rate", "total_contract_value", "column_break_5",
    "notes", "pricing_config_snapshot"
  ],
  "fields": [
    {"fieldname": "naming_series", "fieldtype": "Select", "label": "Series", "options": "CQ-.YYYY.-", "default": "CQ-.YYYY.-", "reqd": 1},
    {"fieldname": "status", "fieldtype": "Select", "label": "Status", "options": "Draft\nGenerated\nSent\nApproved\nRejected\nExpired", "default": "Draft", "in_list_view": 1, "in_standard_filter": 1},
    {"fieldname": "customer", "fieldtype": "Link", "label": "Customer", "options": "Customer", "reqd": 1, "in_list_view": 1},
    {"fieldname": "customer_priority", "fieldtype": "Data", "label": "Customer Priority (at quote time)", "read_only": 1},
    {"fieldname": "column_break_1", "fieldtype": "Column Break"},
    {"fieldname": "valid_until", "fieldtype": "Date", "label": "Valid Until"},
    {"fieldname": "prepared_by", "fieldtype": "Data", "label": "Prepared By"},
    {"fieldname": "section_requirement", "fieldtype": "Section Break", "label": "Requirement"},
    {"fieldname": "years_experience", "fieldtype": "Int", "label": "Years of Experience"},
    {"fieldname": "certification_required", "fieldtype": "Check", "label": "Certification Required"},
    {"fieldname": "certification_held", "fieldtype": "Check", "label": "Certification Held"},
    {"fieldname": "skill_type", "fieldtype": "Select", "label": "Skill Type", "options": "Regular\nNiche", "default": "Regular"},
    {"fieldname": "column_break_2", "fieldtype": "Column Break"},
    {"fieldname": "duration_months", "fieldtype": "Int", "label": "Duration (Months)"},
    {"fieldname": "budget_per_month", "fieldtype": "Currency", "label": "Budget per Month"},
    {"fieldname": "section_resource", "fieldtype": "Section Break", "label": "Resource"},
    {"fieldname": "resource_type", "fieldtype": "Select", "label": "Resource Type", "options": "Internal\nExternal", "default": "Internal", "in_list_view": 1},
    {"fieldname": "employee", "fieldtype": "Link", "label": "Employee", "options": "Employee", "depends_on": "eval:doc.resource_type=='Internal'"},
    {"fieldname": "supplier", "fieldtype": "Link", "label": "Supplier", "options": "Supplier", "depends_on": "eval:doc.resource_type=='External'"},
    {"fieldname": "resource_name", "fieldtype": "Data", "label": "Resource Name", "in_list_view": 1},
    {"fieldname": "column_break_3", "fieldtype": "Column Break"},
    {"fieldname": "monthly_cost", "fieldtype": "Currency", "label": "Monthly Cost (Internal Only)"},
    {"fieldname": "manual_cost", "fieldtype": "Check", "label": "Cost Entered Manually"},
    {"fieldname": "section_pricing", "fieldtype": "Section Break", "label": "Pricing"},
    {"fieldname": "price_good", "fieldtype": "Currency", "label": "Good Price / Month"},
    {"fieldname": "price_better", "fieldtype": "Currency", "label": "Better Price / Month"},
    {"fieldname": "price_best", "fieldtype": "Currency", "label": "Best Price / Month"},
    {"fieldname": "column_break_4", "fieldtype": "Column Break"},
    {"fieldname": "min_bill_amount", "fieldtype": "Currency", "label": "Minimum Bill Amount / Month"},
    {"fieldname": "tier_selected", "fieldtype": "Select", "label": "Tier Selected", "options": "Good\nBetter\nBest\nCustom"},
    {"fieldname": "discount_pct_applied", "fieldtype": "Percent", "label": "Discount % Applied"},
    {"fieldname": "section_final", "fieldtype": "Section Break", "label": "Final"},
    {"fieldname": "final_monthly_rate", "fieldtype": "Currency", "label": "Final Monthly Rate", "in_list_view": 1},
    {"fieldname": "total_contract_value", "fieldtype": "Currency", "label": "Total Contract Value"},
    {"fieldname": "column_break_5", "fieldtype": "Column Break"},
    {"fieldname": "notes", "fieldtype": "Small Text", "label": "Notes"},
    {"fieldname": "pricing_config_snapshot", "fieldtype": "Long Text", "label": "Pricing Config Snapshot (JSON)", "read_only": 1}
  ],
  "permissions": [
    {"role": "Quote Tool API", "read": 1, "write": 1, "create": 1, "delete": 0, "export": 1, "report": 1},
    {"role": "System Manager", "read": 1, "write": 1, "create": 1, "delete": 1, "export": 1, "report": 1}
  ],
  "sort_field": "modified",
  "sort_order": "DESC"
}
